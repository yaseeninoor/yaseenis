<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Yaseenis Islamic Portal</title>
    <style>
        /* (நீங்கள் வழங்கிய அதே CSS-ஐ இங்கே பேஸ்ட் செய்யவும்) */
    </style>
</head>
<body>

    <div id="pageLoader">ஏற்றப்படுகிறது (Loading)...</div>

    <div class="container">
        <div id="authScreen">
            <div class="login-icon">👤</div>
            <h2 id="authTitle">User Login</h2>
            <p id="authSubtitle">உங்கள் கணக்கிற்குள் நுழையவும்.</p>
            
            <div class="input-group">
                <label>Email Address</label>
                <input type="email" id="emailInput" class="input-field" placeholder="yourname@email.com">
            </div>

            <div class="input-group">
                <label>Password</label>
                <input type="password" id="passwordInput" class="input-field" placeholder="Enter password">
            </div>

            <button id="mainAuthBtn" class="action-btn">Login</button>
            
            <p class="toggle-text">
                <span id="toggleQuestion">புதிய பயனரா?</span> 
                <span class="toggle-link" id="toggleLink">Register Here</span>
            </p>

            <div id="errorMsg" class="error-msg"></div>
            <div id="successMsg" class="success-msg"></div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-app.js";
        import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-auth.js";

        const firebaseConfig = {
            apiKey: "AIzaSyA58LsyYjrJuZDChB9TaM5FUnHE-UMFl5o",
            authDomain: "yaseenis-user.firebaseapp.com",
            projectId: "yaseenis-user",
            storageBucket: "yaseenis-user.firebasestorage.app",
            messagingSenderId: "337971140829",
            appId: "1:337971140829:web:c30a126aac465ded12e334"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);

        let isLoginMode = true;
        const mainAuthBtn = document.getElementById("mainAuthBtn");
        const toggleLink = document.getElementById("toggleLink");
        const emailInput = document.getElementById("emailInput");
        const passwordInput = document.getElementById("passwordInput");
        const errorMsg = document.getElementById("errorMsg");
        const successMsg = document.getElementById("successMsg");

        // Toggle UI
        toggleLink.onclick = () => {
            isLoginMode = !isLoginMode;
            document.getElementById("authTitle").innerText = isLoginMode ? "User Login" : "Create Account";
            mainAuthBtn.innerText = isLoginMode ? "Login" : "Sign Up";
            toggleLink.innerText = isLoginMode ? "Don't have an account? Register" : "Already have an account? Login";
        };

        // Authentication Logic
        mainAuthBtn.onclick = () => {
            const email = emailInput.value;
            const password = passwordInput.value;
            errorMsg.style.display = "none";
            successMsg.style.display = "none";

            if(isLoginMode) {
                signInWithEmailAndPassword(auth, email, password)
                    .catch(e => { errorMsg.innerText = e.message; errorMsg.style.display = "block"; });
            } else {
                createUserWithEmailAndPassword(auth, email, password)
                    .then(() => { successMsg.innerText = "பதிவு வெற்றி!"; successMsg.style.display = "block"; })
                    .catch(e => { errorMsg.innerText = e.message; errorMsg.style.display = "block"; });
            }
        };

        // Redirection
        onAuthStateChanged(auth, (user) => {
            document.getElementById("pageLoader").style.display = "none";
            if (user) window.location.replace("index.html");
        });
    </script>
</body>
</html>
