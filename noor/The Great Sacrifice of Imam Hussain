    <div class="container">
        
        <!-- 🔒 LOCK SCREEN -->
        <div id="lockScreen">
            <div style="font-size: 50px; margin-bottom: 15px;">🔒</div>
            <h2>Protected Post</h2>
            <p>கர்பலா வரலாற்றுப் பதிவைப் படிக்க கடவுச்சொல்லை (Password) உள்ளிடவும்.</p>
            
            <input type="password" id="pwdInput" class="password-input" placeholder="Enter Password">
            <button class="unlock-btn" onclick="checkPassword()">Unlock Post</button>
            
            <div id="errorMsg" class="error-msg">தவறான கடவுச்சொல்! (Wrong Password)</div>
        </div>

        <!-- 🔓 SECRET CONTENT (Karbala Post) -->
        <div id="secretContent">
            
            <a href="/" style="display: inline-flex; align-items: center; gap: 5px; text-decoration: none; color: var(--emerald-dark); font-weight: 600; margin-bottom: 20px; font-family: 'Inter', sans-serif;">
                ← Back to Home
            </a>

            <article class="article-card">
                <div style="text-align: center;">
                    <span style="display:inline-block; background: var(--gold-light); color: var(--gold-premium); padding: 5px 15px; border-radius: 8px; font-size: 13px; font-weight: 700; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 1px;">History / வரலாறு</span>
                </div>
                
                <!-- TANGLISH TITLE -->
                <h1 class="article-title">Karbala Varalaru: The Great Sacrifice of Imam Hussain (RA)</h1>
                
                <div class="author-name">Posted by: Yaseenis Media</div>
                
                <p class="tamil-text">
                    கர்பலா வரலாறு (History of Karbala) இஸ்லாமிய சரித்திரத்தில் தியாகத்தின் உச்சத்தை உணர்த்தும் ஒரு கண்ணீர் மல்க வைக்கும் நிகழ்வாகும். ஹிஜ்ரி 61, முஹர்ரம் மாதம் 10-ம் நாள் ஈராக் நாட்டின் கர்பலா மைதானத்தில் இந்த மாபெரும் தியாகம் நடைபெற்றது.
                </p>
                
                <p class="tamil-text">
                    சத்தியத்தை நிலைநாட்டுவதற்காகவும், இஸ்லாமிய மார்க்கத்தின் புனிதத்தைக் காப்பதற்காகவும் நபிகள் நாயகம் (ஸல்) அவர்களின் அருமைப் பேரர் இமாம் ஹுஸைன் (ரலி) அவர்கள் தமது குடும்பத்தினர் மற்றும் உற்ற தோழர்களுடன் இணைந்து செய்த தியாகம் உலக வரலாற்றில் ஈடு இணையற்றது.
                </p>

                <div class="quote-box">
                    "கொடுங்கோலன் முன்னால் உண்மையை எடுத்துரைப்பதே மிகச் சிறந்த அறப்போராட்டமாகும்" - என்ற நாயகம் (ஸல்) அவர்களின் கூற்றுக்கேற்ப வாழ்ந்து காட்டியவர்கள் இமாம் ஹுஸைன் (ரலி) அவர்கள்.
                </div>
                
                <p class="tamil-text">
                    அநியாயக்கார ஆட்சியாளர் யஸீதின் தவறான அதிகாரத்திற்கு அடிபணிய மறுத்து, பல நாட்கள் குடிக்கத் தண்ணீர் கூட இல்லாமல், தாகத்தோடு நீதிக்காக உயிர்நீத்த அஹ்லுல் பைத் (நபிக்குடும்பம்) மற்றும் சஹாபாக்களின் ஈமானிய உறுதி நமக்கு என்றென்றும் ஒரு சிறந்த பாடமாகும். கர்பலா வெறும் ஒரு துயரச் சம்பவம் மட்டுமல்ல; அது சத்தியமும் அசத்தியமும் மோதிய போது, சத்தியம் எவ்விதம் நிலைத்து நின்றது என்பதற்கான அழியாத சாட்சியாகும்.
                </p>

            </article>
            
            <button class="lock-again-btn" onclick="lockPageAgain()">🔒 Lock this post again</button>
        </div>

    </div>

    <!-- JavaScript For Password Protection -->
    <script>
        // 🔑 உங்களின் புதிய கடவுச்சொல் (Password): yaseeni
        const correctPassword = "yaseeni"; 

        function checkPassword() {
            const userInput = document.getElementById("pwdInput").value.toLowerCase(); // Case insensitive
            const errorMsg = document.getElementById("errorMsg");
            const lockScreen = document.getElementById("lockScreen");
            const secretContent = document.getElementById("secretContent");

            if (userInput === correctPassword) {
                lockScreen.style.display = "none";
                secretContent.style.display = "block";
                document.getElementById("pwdInput").value = ""; 
                errorMsg.style.display = "none";
                window.scrollTo(0,0); 
            } else {
                errorMsg.style.display = "block";
            }
        }

        function lockPageAgain() {
            document.getElementById("secretContent").style.display = "none";
            document.getElementById("lockScreen").style.display = "block";
            window.scrollTo(0,0);
        }
        
        document.getElementById("pwdInput").addEventListener("keypress", function(event) {
            if (event.key === "Enter") {
                event.preventDefault();
                checkPassword();
            }
        });
    </script>

</body>
