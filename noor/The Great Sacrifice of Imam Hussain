        .password-input { width: 100%; padding: 15px; border: 2px solid var(--border-light); border-radius: 8px; font-size: 18px; text-align: center; box-sizing: border-box; margin-bottom: 20px; outline: none; transition: 0.3s; font-family: 'Inter', sans-serif; letter-spacing: 2px; }
        .password-input:focus { border-color: var(--emerald-main); }
        
        .unlock-btn { background: var(--emerald-main); color: white; width: 100%; padding: 15px; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; transition: 0.3s; font-family: 'Inter', sans-serif; }
        .unlock-btn:hover { background: var(--gold-premium); }
        .error-msg { color: #ef4444; font-size: 14px; margin-top: 10px; display: none; font-weight: bold; }

        /* --- SECRET CONTENT (HIDDEN BY DEFAULT) --- */
